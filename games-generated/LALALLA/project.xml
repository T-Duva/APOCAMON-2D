<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- paths -->

	<set name="stencylInstall" value="F:/PROGRAMACION/juego8b/Stencyl-4.1.4" />
	<set name="stencylLibrary" value="F:/PROGRAMACION/juego8b/Stencyl-4.1.4/Juegos/stencylworks" />
	<set name="androidBuildsPath" value="C:/Users/Usuario/AppData/Local/Stencyl/android-builds" />

	<!-- variables -->
	
	<set name="cppia" if="stencyl-cppia" />
	<set name="telemetry" if="false" unless="mobile || cppia" />
	<set name="publishing" if="false" />
	<set name="iosDevice" value="universal" if="ios" /> <!-- iphone, ipad, or universal -->
	<set name="enableHxcppDebugger" value="false" />
	<set name="enableHxcppStack" value="true" />
	<set name="enableHxcppDebugLink" value="false" />
	<set name="enableStencylTools" value="true" />
	<set name="sitelock-class" value="com.stencyl.loader.SiteLock" />

	<!-- hack -->
	<set name="desktop" value="true" if="cppia" />
	<set name="disable-version-check" /> <!-- To allow us to bundle any openfl/lime -->
	
	<!-- basic info -->

	<meta title="LALALLA" company="Stencyl" />
	<meta title="My Game" package="com.yourcompany.gamename" version="1.0.0" if="mac" />
	<meta title="My Game" package="com.yourcompany.gamename" version="1.0.0" if="ios" />
	<meta title="My Game" package="com.yourcompany.gamename" version="1.0.0" if="android" />

	<app main="Universal" file="LALALLA" path="Export" preloader="com.stencyl.loader.StencylPreloader" />
	<app file="My Game" if="mac" />
	<config:html5 output-directory="html5" />
	
	<set name="SWF_VERSION" value="11.3" />
	
	<window resizable="false" fps="65" vsync="true" background="0x000000"/>
	<window width="0" height="0" orientation="portrait" if="mobile" />
	<window width="1920" height="1080" fullscreen="false" allowHighDPI="false" if="desktop" />
	<window width="1280" height="720" allowHighDPI="false" if="flash || html5" />
	<window allow-shaders="true" alwaysOnTop="false" antialiasing="0" borderless="false" color-depth="32"
			depth-buffer="true" hardware="true" maximized="false" minimized="false" orientation="auto"
			require-shaders="false" resizable="true" stencil-buffer="true" title="" if="cppia" />
	<haxedef name="openfl_disable_hdpi" if="mobile" />
	<haxedef name="openfl_dpi_aware" if="mobile" />
	
	<source path="Source" />
	
	<haxelib name="com.stencyl" />
	<template path="${stencylInstall}/plaf/lime-templates" rename="templates" />
	<template path="${stencylInstall}/plaf/lime-templates-publishing" rename="templates" if="publishing" />

	<section if="cpp ${enableHxcppDebugLink}">
		<haxedef name="HXCPP_DEBUG_LINK" unless="android" />
		<haxedef name="HXCPP_DEBUG_LINK_AND_STRIP" if="android" />
	</section>
	<section if="cpp" unless="${enableHxcppDebugLink}">
		<haxedef name="HXCPP_NO_DEBUG_LINK" />
	</section>
	

	<section if="publishing">
		<haxeflag name="--no-traces" if="flash || html5" />
	</section>
	<section unless="publishing" >
		<haxedef name="testing" />
		<set name="testing" value="true" />
		<haxedef name="stencyltools" if="${enableStencylTools}" />
		<section if="cpp ${enableHxcppStack}">
			<haxedef name="HXCPP_STACK_TRACE" />
			<haxedef name="HXCPP_STACK_LINE" />
			<haxedef name="HXCPP_CHECK_POINTER" />
		</section>
	</section>

	<haxedef name="use_tilemap" unless="flash" />

	<!--========================
	-   assets and config files
	==========================-->

	<!-- project scales: ["1x"] -->
	
	<set name="excludeScales" value="" if="web" />
	<set name="excludeScales" value="" if="desktop" />
	<set name="excludeScales" value="" if="android" />
	<set name="excludeScales" value="" if="ios" />
	<set name="excludeScales" value="${excludeScales}|4x" if="ios ${iosDevice == iphone}" />
	
	<!-- game assets --> 
	
	<assets path="Assets/graphics" rename="assets/graphics" include="*" exclude="${excludeScales}" /> 
	
	<assets path="Assets/music" rename="assets/music" type="music" include="*.mp3" if="flash || html5" />
	<assets path="Assets/music" rename="assets/music" type="music" include="*.ogg" unless="flash" />
	
	<assets path="Assets/sfx" rename="assets/sfx" type="sound" include="*.mp3" if="flash || html5" />
	<assets path="Assets/sfx" rename="assets/sfx" type="sound" include="*.ogg" unless="flash" />
	
	<assets path="Assets/data" rename="assets/data" include="*" />
	
	<!-- game configuration files, preloaded/embedded -->

	<assets path="Config" rename="config" if="testing" />
	<section if="flash || html5 || publishing">
		<haxeflag name="-resource" value="Config/game-config.json@config_game_config_json" />
		<haxeflag name="-resource" value="Config/preloadPaths.txt@config_preloadpaths_txt" />
		<haxeflag name="-resource" value="Config/preloader-badge.png@config_preloader_badge_png" unless="html5" />
		<haxeflag name="-resource" value="Config/preloader-badge.txt@config_preloader_badge_txt" if="html5" />
	</section>


	<!--========================
	-   icons
	==========================-->
	
	<set name="icons" value="Images/icon" />

	<icon path="${icons}/Icon.png" size="57" />
	<icon path="${icons}/Icon@2x.png" size="114" />
	<icon path="${icons}/Icon-72.png" size="72" />
	<icon path="${icons}/Icon-72@2x.png" size="144" />

	<icon path="${icons}/Icon-48.png" size="48" />
	<icon path="${icons}/Icon-76.png" size="76" />
	<icon path="${icons}/Icon-96.png" size="96" />
	<icon path="${icons}/Icon-120.png" size="120" />
	<icon path="${icons}/Icon-128.png" size="128" />
	<icon path="${icons}/Icon-152.png" size="152" />
	<icon path="${icons}/Icon-256.png" size="256" />
	<icon path="${icons}/Icon-512.png" size="512" />
	<icon path="${icons}/Icon-1024.png" size="1024" />

	<section if="desktop">
		
		<icon path="${icons}/Icon-16.png" size="16" />
		<icon path="${icons}/Icon-24.png" size="24" />
		<icon path="${icons}/Icon-32.png" size="32" />
		
	</section>
	
	<!--========================
	-   extensions
	==========================-->

	<set name="enable_com.stencyl.native" value="true" />
	<set name="enable_com.stencyl.joystick" value="true" />
	<set name="enable_com.stencyl.gestures" value="true" />
	
	<haxelib name="com.stencyl.native" if="${enable_com.stencyl.native} mobile" />
	<haxelib name="com.stencyl.joystick" if="${enable_com.stencyl.joystick}" />
	<haxelib name="com.stencyl.gestures" if="${enable_com.stencyl.gestures}" />
	
	<config:stencyl>
		<extension classname="com.stencyl.native.Native" if="${enable_com.stencyl.native} mobile" condition="com.stencyl.native" />
	</config:stencyl>
	
	<!--========================
	-   platform sections
	==========================-->

	<section if="android">

		<android permission="android.permission.WAKE_LOCK" />
		<android permission="android.permission.INTERNET" />
		<android permission="android.permission.VIBRATE" />
		<android permission="android.permission.ACCESS_NETWORK_STATE" />
		
		
		
		<android minimum-sdk-version="14" />
		<android target-sdk-version="33" />

		<config:android gradle-version="8.5" />
		<config:android gradle-plugin="8.1.3" />
		
		<config:android gradle-build-directory="${androidBuildsPath}" />
		
		<meta build-number="1" />
		
		<architecture name="arm64" if="publishing" />
		 
	</section>
	
	<section if="ios">

		<set name="iosSdk" value="0.0" />

		
		
		<launchStoryboard template="splash.storyboard" assetsPath="Images/splash" bg:RGB="0x000000"
			contentMode="center"
			ipad="ipad-splash-sb.png" portrait="iphone-splash-sb.png">

			<imageset name="ipad-splash-sb.png" unless="${iosDevice == iphone}" />
			<imageset name="iphone-splash-sb.png" unless="${iosDevice == ipad}" />
		
		</launchStoryboard>
		
		<ios deployment="${iosSdk}" devices="${iosDevice}" />
		
		<setenv name="IPHONE_VER" value="0.0" />
		<setenv name="APP_BUILD_NUMBER" value="[VERSION]" />
		<setenv name="APP_TITLE" value="My Game" />
		<setenv name="HXCPP_CLANG" value="true" />
		<setenv name="PRERENDERED_ICON" value="true" />

		<config:ios non-exempt-encryption="false" />

		<meta build-number="1" />
		
		
	</section>
	
	<section if="mac">
	
		<setenv name="APP_TITLE" value="My Game" />
		<meta build-number="1" />

		<define name="MACOSX_DEPLOYMENT_TARGET" value="10.9" />
		<setenv name="MACOSX_DEPLOYMENT_TARGET" value="10.9" />
	
	</section>
	
	<section if="windows" unless="hl">
		
		<architecture name="x86" exclude="x64" />
		
	</section>
	
	<section if="html5">
		
		<library name="default" type="gzip" if="publishing" />
		
	</section>
	
	<section if="telemetry">
		
		<config:hxtelemetry allocations="true" />
		<config:hxtelemetry host="192.168.0.195" if="mobile" />
		<config:hxtelemetry host="localhost" unless="mobile" />
		
	</section>

	<section if="cpp ${enableHxcppDebugger}">

		<haxelib name="hxcpp-debug-server" />
		<haxedef name="HXCPP_DEBUG_HOST" value="192.168.0.195"  if="mobile" />
		<haxedef name="HXCPP_DEBUG_HOST" value="localhost" unless="mobile" />
		<haxedef name="HXCPP_DEBUGGER" />

	</section>
	
	
	
	

</project>
